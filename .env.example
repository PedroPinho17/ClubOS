# ---------------------------------------------------------------------------
# ClubOS - Variaveis de ambiente (copiar para .env)
# ---------------------------------------------------------------------------

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://clubos:clubos@localhost:5432/clubos?schema=public"

# --- API (NestJS) ---
API_PORT=4000
NODE_ENV=development
# URL do frontend (links em emails: reset password, portal, lembretes, QR).
# Multiplas origens: separar por virgula (ex.: http://localhost:3000,http://127.0.0.1:3000)
WEB_ORIGIN="http://localhost:3000"

# --- Better Auth ---
BETTER_AUTH_SECRET="troca-isto-por-um-segredo-forte-de-32+chars"
# URL base da API (sem /api) — Better Auth monta /api/auth/*
BETTER_AUTH_URL="http://localhost:4000"
# WebAuthn / passkeys
PASSKEY_RP_ID="localhost"

# OAuth (preparado — ainda nao ligado no Better Auth; ignorar em dev)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- Redis (cache, sessoes, filas BullMQ) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# --- Email (SMTP) ---
# Obrigatorio em producao para: reset password (/recuperar-password -> /reset-password),
# convites portal, lembretes de quota e comunicacoes.
# Sem SMTP_HOST => modo dev: emails apenas registados no log (nao enviados).
MAIL_FROM="ClubOS <no-reply@clubos.local>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# --- S3 / MinIO (ficheiros) ---
S3_ENDPOINT="http://localhost:9000"
S3_REGION="eu-west-1"
S3_BUCKET="clubos"
S3_ACCESS_KEY="clubos"
S3_SECRET_KEY="clubos-secret"
S3_FORCE_PATH_STYLE=true

# Assinatura dos QR de validacao (opcional; usa BETTER_AUTH_SECRET se vazio)
QR_SIGNING_SECRET=""

# --- Sentry (opcional — sem DSN = zero impacto em dev/CI) ---
# API: SENTRY_DSN | Web: NEXT_PUBLIC_SENTRY_DSN (e SENTRY_DSN no servidor Next)
SENTRY_DSN=""
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_DSN=""

# --- Lembretes automaticos de quotas ---
# REMINDERS_ENABLED=true activa cron diario 09:00. Manual: pnpm --filter @clubos/api reminders:run
REMINDERS_ENABLED=false
# REMINDERS_CRON="0 9 * * *"
# Ping Healthchecks.io apos cada execucao do job (opcional)
HEALTHCHECK_QUOTA_REMINDERS_URL=""

# --- Rate limit (API) ---
# Em producao usa Redis (partilha contadores entre replicas). memory = so este processo.
RATE_LIMIT_STORE=redis
RATE_LIMIT_AUTH_PER_MIN=15
RATE_LIMIT_VALIDATE_PER_MIN=60
# Confiar no proxy reverso para IP real (Coolify/Traefik/Caddy). TRUST_PROXY=false desactiva.
TRUST_PROXY=true
# TRUST_PROXY_HOPS=1

# --- Seed demo (apenas local; nao commitar password real) ---
SEED_DEMO_PASSWORD="altera-isto-no-teu-env-local"

# --- Playwright E2E (apps/web) ---
E2E_USER_EMAIL="admin@crcvale.pt"
E2E_SOCIO_EMAIL="joao@example.com"
# Se vazio, os testes usam SEED_DEMO_PASSWORD (recomendado — mesma password do seed)
E2E_USER_PASSWORD=""
E2E_BASE_URL="http://localhost:3000"
# true = API+Web ja a correr noutro terminal (pnpm dev); false = Playwright arranca API+Web (CI)
E2E_SKIP_WEBSERVER=false
# Opcional: forcar build de producao nos E2E locais (por omissao so em CI)
# E2E_USE_PROD_SERVERS=true

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL="http://localhost:4000"
# Docker/Linux: standalone activo por omissao. Windows local: NEXT_STANDALONE=false
# NEXT_STANDALONE=false
