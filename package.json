{
  "name": "clubos",
  "version": "0.1.0",
  "private": true,
  "description": "ClubOS - Plataforma SaaS modular multi-tenant para gestao de organizacoes (clubes, academias, associacoes).",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @clubos/database generate",
    "db:migrate": "pnpm --filter @clubos/database migrate",
    "db:push": "pnpm --filter @clubos/database push",
    "db:seed": "pnpm --filter @clubos/database seed && pnpm --filter @clubos/api seed:users",
    "db:studio": "pnpm --filter @clubos/database studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2"
  }
}
