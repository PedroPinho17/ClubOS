{
  "name": "clubos",
  "version": "0.1.0",
  "private": true,
  "description": "ClubOS - Plataforma SaaS modular multi-tenant para gestao de organizacoes (clubes, academias, associacoes).",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @clubos/database generate",
    "db:migrate": "pnpm --filter @clubos/database migrate",
    "db:deploy": "pnpm --filter @clubos/database run migrate:deploy",
    "db:push": "pnpm --filter @clubos/database push",
    "db:seed": "pnpm --filter @clubos/database seed && pnpm --filter @clubos/api seed:users",
    "db:studio": "pnpm --filter @clubos/database studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build",
    "db:backup": "node scripts/run-backup.mjs",
    "db:restore": "node scripts/run-backup.mjs restore",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,json,md,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.4.2",
    "turbo": "^2.10.4",
    "typescript": "^5.7.2"
  }
}
